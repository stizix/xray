{
  "manifest_version": 3,
  "name": "XRay",
  "version": "1.0.0",
  "description": "Track unfollowers, scan tweet engagement, and collect X data — silently.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "XRay",
    "default_icon": {
      "128": "icons/logo.svg"
    }
  },
  "icons": {
    "128": "icons/logo.svg"
  }
}
